{
  "version": 2,
  "installCommand": "echo 'Skipping install — handled by build.sh'",
  "buildCommand": "sh build.sh",
  "outputDirectory": "build/web",
  "cleanUrls": true,
  "trailingSlash": false,
  "framework": null,
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }

  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cross-Origin-Embedder-Policy",
          "value": "credentialless"
        },
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin"
        }
      ]
    }
  ]
}
